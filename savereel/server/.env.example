# ─── Required ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# URL of your deployed frontend (no trailing slash)
CLIENT_URL=https://savereel.app

# ─── Optional ─────────────────────────────────────────────────────────────────

# Secret header value for GET /health/details
# Add header: X-Health-Secret: <value>
# Leave blank to disable the endpoint protection (not recommended in prod)
HEALTH_SECRET=change-me-to-a-random-string

# Redis connection string for rate-limit-redis store (optional)
# REDIS_URL=redis://localhost:6379

# Sentry error tracking DSN (optional)
# SENTRY_DSN=https://xxx@sentry.io/yyy
